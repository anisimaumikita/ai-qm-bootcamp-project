{
  "name": "ikea-jobs-automation",
  "version": "1.0.0",
  "description": "Playwright + TypeScript QA automation for IKEA Jobs website",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:scenario1": "playwright test tests/scenarios/scenario1.spec.ts",
    "test:scenario2": "playwright test tests/scenarios/scenario2.spec.ts",
    "test:scenario3": "playwright test tests/scenarios/scenario3.spec.ts",
    "codegen": "playwright codegen https://www.ikea.com/",
    "report": "playwright show-report",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "typescript",
    "pom",
    "qa-automation"
  ],
  "author": "QA Automation Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.3"
  }
}
